# Dependencies
node_modules/
.pnp
.pnp.js
# bun.lock is generated by the SessionStart hook's `bun install`;
# npm's package-lock.json is the source of truth for this repo.
bun.lock

# Build output
# out/    = electron-vite renderer/main/preload bundles
# dist/   = electron-builder installers
# dist-*/ = alternate electron-builder outputs (auto-update test harness)
out/
dist/
dist-*/
*.tsbuildinfo
.vite/

# Test / tooling artifacts
coverage/
storybook-static/
playwright-report/
test-results/
blob-report/
.eslintcache

# Local runtime / staged binaries are handled by bin/.gitignore
# (Python, edison-stdiod, and node/uv runtimes are staged into bin/ at build time)

# Environment & secrets
.env
.env.*
!.env.example
dev-app-update.yml

# Editor / OS
.DS_Store
*.log
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Claude Code
.claude/

# Local-only build helper (kept out of git)
/build-linux.yml
