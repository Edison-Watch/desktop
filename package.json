{
  "name": "edison-watch-client-2",
  "version": "0.3.0",
  "private": true,
  "description": "Edison Watch Desktop Client v2 - Electron + React 19",
  "main": "./out/main/index.js",
  "author": "Edison Watch Team <hello@edison.watch>",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:dry": "cross-env EDISON_DRY_RUN=1 electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:demo": "npm run typecheck && electron-vite build --mode demo",
    "build:release": "npm run typecheck && electron-vite build --mode release",
    "build:mac": "npm run build:demo && electron-builder --mac",
    "build:mac:release": "npm run build:release && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test --config playwright.config.ts",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build",
    "visual-test": "playwright test --config=playwright.visual.config.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@sentry/electron": "^7.8.0",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.0",
    "eventsource": "^3.0.7",
    "jsonc-parser": "^3.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@edison/shared": "*",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/addon-vitest": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.1",
    "http-server": "^14.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.14",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.7.0",
    "vitest": "^4.0.18"
  }
}
